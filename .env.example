# ════════════════════════════════════════════════════════════════
#  AG Pro 3.1 — Variables de entorno (TEMPLATE)
#  Copiar a .env y rellenar con valores reales.
#  NUNCA commitear .env con valores reales.
# ════════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────────
APP_ENV=development              # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ─── Webhook TradingView ────────────────────────────────────────
# Passphrase larga y aleatoria. Mínimo 32 caracteres.
WEBHOOK_PASSPHRASE=cambia_esto_por_un_string_largo_y_aleatorio_de_32_chars_min

# ─── Broker: Binance Futuros (CCXT) ─────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true             # true = paper trading, false = real money

# ─── Broker: OANDA (forex/metales) ──────────────────────────────
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice               # practice | live

# ─── Telegram Alerts ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                # Tu user_id (pedíle al bot @userinfobot)

# ─── Risk Management (CRÍTICO) ──────────────────────────────────
RISK_TARGET_VOL=0.15             # 15% vol anualizada objetivo
RISK_MAX_POSITION_PCT=0.25       # Max 25% equity en 1 trade
RISK_MAX_EXPOSURE_PCT=0.50       # Max 50% equity total (long+short)
RISK_MAX_DAILY_LOSS_PCT=0.03     # -3% en el día = stop
RISK_MAX_DRAWDOWN_PCT=0.15       # -15% DD = pausar 24h
RISK_KILL_SWITCH=false           # true = no abrir nuevos trades

# ─── Datos ──────────────────────────────────────────────────────
# Path a Dukascopy CLI (solo si se usa download_duka.py)
DUKA_PATH=
# Directorio base para datos históricos cacheados
DATA_DIR=./data
